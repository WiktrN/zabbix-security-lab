# Wykrywanie Pinga (najprostszy test)
alert icmp any any -> any any (msg:"GPC PING DETECTED"; sid:1000001; rev:1;)

# Wykrywanie skanowania Nmap (User-Agent)
alert http any any -> any any (msg:"GPC NMAP Scan Detected"; content:"nmap"; http_user_agent; sid:1000002; rev:1;)

# Wykrywanie prób skanowania portów (SYN scan)
alert tcp any any -> $HOME_NET any (msg:"GPC Potential SSH Brute Force"; flags:S; threshold:type both, track by_src, count 5, seconds 60; sid:1000003; rev:1;)
